{
  "name": "skylight-ar",
  "version": "0.1.0",
  "private": true,
  "description": "Sky AR — point your phone at the sky and see the aircraft, planets, and ISS overhead, live.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -F web build",
    "preview": "pnpm -F web preview",
    "test": "vitest run",
    "typecheck": "tsc -p shared/tsconfig.json && pnpm -F web typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
